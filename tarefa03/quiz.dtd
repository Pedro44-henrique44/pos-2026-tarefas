<!ELEMENT quiz (disciplina, professor, turma, data, questoes)> <!-- mudei "questões" para "questoes"-->
    <!ATTLIST quiz versao CDATA #REQUIRED>
    <!ELEMENT disciplina (#PCDATA)>
    <!ELEMENT professor (nome, matricula?)>
        <!ELEMENT nome (#PCDATA)>
        <!ELEMENT matricula (#PCDATA)> <!-- tirei o acento do i-->
    <!ELEMENT turma (#PCDATA)>
    <!ELEMENT data (#PCDATA)>
    <!ELEMENT questoes (questao+)>
        <!ELEMENT questao (enunciado, pontuaçao, alternativas)> <!-- tirei os acentos circunflexos-->
            <!ELEMENT enunciado (#PCDATA)>
            <!ELEMENT pontuaçao (#PCDATA)>
            <!ELEMENT alternativas (alternativa+)>
                <!ELEMENT alternativa (#PCDATA)>
                    <!ATTLIST alternativa correta (sim|nao) #REQUIRED>